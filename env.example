# Copy to .env.local and set the URL of your deployed backend.
# For Vercel serverless deployment, leave VITE_API_URL blank to use same-origin /api routes.

VITE_API_URL=http://localhost:8000

# Supabase backend settings for local development or Vercel serverless functions
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
